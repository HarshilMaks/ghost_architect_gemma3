FROM mcr.microsoft.com/playwright/python:v1.48.0-jammy

WORKDIR /app

# Copy requirements and install specific playwright version to match base image
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt playwright==1.48.0

# Copy project
COPY . .

# Set environment
ENV PYTHONUNBUFFERED=1

# Run data factory
ENTRYPOINT ["python", "scripts/data_factory.py"]
CMD ["100"]
